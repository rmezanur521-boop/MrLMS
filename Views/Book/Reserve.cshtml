@model MrLMS.Models.ViewModels.VmReserveBook
@{
    ViewData["Title"] = "Reserve Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="container-fluid px-3">
    <div class="reserve-wrap">

        <!-- Title -->
        <div class="reserve-header">
            <i class="bi bi-bookmark-plus-fill" style="color:#e8604c"></i>
            Reserve a Book
        </div>

        <!-- Alerts -->
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning border-0 rounded-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Warning"]
            </div>
        }

        <!-- Book Summary -->
        <div class="book-summary-card">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Url.Content("~/images/" + Model.ImageUrl)" alt="@Model.Title" />
            }
            else
            {
                <div class="no-img"><i class="bi bi-book"></i></div>
            }
            <div class="info">
                <div class="title">@Model.Title</div>
                <div class="meta"><strong>Author(s):</strong> @Model.Authors</div>
                <div class="meta"><strong>Genre:</strong> @(Model.GenreName ?? "—")</div>
                <div class="meta"><strong>Publication:</strong> @(Model.Publication ?? "—")</div>
            </div>
        </div>

        <!-- Reservation Form -->
        <div class="reservation-form-card">
            <h6><i class="bi bi-calendar-check me-2 text-danger"></i>Reservation Details</h6>

            <div class="info-note">
                <i class="bi bi-info-circle-fill me-2"></i>
                Please select your preferred reservation start date and due date.
                Your due date is pre-filled based on your subscription.
            </div>

            <form asp-action="ConfirmReservation"
                  asp-controller="Book"
                  method="post">
                @Html.AntiForgeryToken()

                <!-- Hidden BookId -->
                <input type="hidden" asp-for="BookId" />

                <div class="row g-3">
                    <!-- From Date -->
                    <div class="col-md-6">
                        <label asp-for="FromDate" class="form-label">From Date</label>
                        <input asp-for="FromDate"
                               type="date"
                               class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="FromDate" class="text-danger small"></span>
                    </div>

                    <!-- Due Date -->
                    <div class="col-md-6">
                        <label asp-for="DueDate" class="form-label">Due Date</label>
                        <input asp-for="DueDate"
                               type="date"
                               class="form-control"
                               min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DueDate" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Member name (display only) -->
                @{
                    var sessionUserName = Context.Session.GetString("UserName");
                    var sessionUserRole = Context.Session.GetString("UserRole");
                }
                <div class="mt-3 p-3 rounded-3" style="background:#f9fafb; border:1px solid #e5e7eb; font-size:0.85rem;">
                    <i class="bi bi-person-circle me-2 text-muted"></i>
                    Reserving as: <strong>@sessionUserName</strong>
                    <span class="ms-2 badge"
                          style="background:#ecfdf5; color:#059669; border:1px solid #a7f3d0; font-size:0.72rem;">
                        @sessionUserRole
                    </span>
                </div>

                <!-- Buttons -->
                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="btn btn-confirm">
                        <i class="bi bi-check-circle-fill me-2"></i>Confirm Reservation
                    </button>
                    <a href="/Book/Details/@Model.BookId" class="btn-cancel">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>