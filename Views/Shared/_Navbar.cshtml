@{
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
}
<nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="dark">
    <div class="container-fluid">

        <!-- BRAND -->
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">LMS</a>

        <!-- TOGGLER -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarColor01">

            <!-- LEFT SIDE MENU -->
            <ul class="navbar-nav me-auto">

                <!-- DASHBOARD -->
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Book" asp-action="AdvancedSearch">AdvancedSearch</a>
                </li>

                <!-- BOOKS -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Books</a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" asp-controller="Book" asp-action="Index">All Books</a>
                        <a class="dropdown-item" asp-controller="Genre" asp-action="Index">Genres</a>
                        <a class="dropdown-item" asp-controller="Author" asp-action="Index">Authors</a>
                        <a class="dropdown-item" asp-controller="BookReview" asp-action="Index">Reviews</a>
                    </div>
                </li>

                <!-- MEMBER SECTION -->
                
                @if (userRole=="Member")
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">My Library</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" asp-controller="Reservation" asp-action="MyReservations">My Reservations</a>
                            <a class="dropdown-item" asp-controller="Reservation" asp-action="History">Borrow History</a>
                        </div>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Subscription</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" asp-controller="Subscription" asp-action="MyPlan">My Plan</a>
                            <a class="dropdown-item" asp-controller="Subscription" asp-action="Upgrade">Upgrade</a>
                        </div>
                    </li>
                }

                <!-- LIBRARIAN -->
                @if (userRole=="Librarian")
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Management</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" asp-controller="Book" asp-action="Create">Add Book</a>
                            <a class="dropdown-item" asp-controller="Book" asp-action="Index">Manage Books</a>
                            <a class="dropdown-item" asp-controller="Author" asp-action="Index">Authors</a>
                            <a class="dropdown-item" asp-controller="Genre" asp-action="Index">Genres</a>
                        </div>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Transactions</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" asp-controller="Reservation" asp-action="Index">Reservations</a>
                            <a class="dropdown-item" asp-controller="Reservation" asp-action="Issue">Issue Book</a>
                            <a class="dropdown-item" asp-controller="Reservation" asp-action="Return">Return Book</a>
                        </div>
                    </li>
                }

                <!-- ADMIN -->
                @if (userRole=="Admin")
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Admin Panel</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" asp-controller="Role" asp-action="Index">Roles</a>
                            <a class="dropdown-item" asp-controller="MemberRole" asp-action="Index">Member Roles</a>
                            <a class="dropdown-item" asp-controller="Subscription" asp-action="Index">Subscriptions</a>
                        </div>
                    </li>
                }

            </ul>

            <!-- RIGHT SIDE (AUTH) -->
            <ul class="navbar-nav ms-auto">

         
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="bi bi-person-circle me-1"></i>
                            @Context.Session.GetString("UserName")
                            <span class="badge bg-light text-dark ms-1" style="font-size:.7rem">
                                @Context.Session.GetString("UserRole")
                            </span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }

            </ul>

        </div>
    </div>
</nav>
